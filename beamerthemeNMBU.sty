\setbeamercolor{title}{fg=NMBUwhite,bg=NMBUPrimary}

\defbeamertemplate*{title page}{NMBU}[1][]{%
  \begin{tikzpicture}[overlay,remember picture]
    \fill[NMBUPrimary]
      (current page.north west) rectangle (current page.south east);

    \node[anchor=north east,inner sep=0pt]
      at ($(current page.north east) + (-0.8,-0.50)$)
      {\resizebox{1.0cm}{!}{\nmbulogo{NMBUwhite}}};

    \NMBU@drawtitlelogorow
    \NMBU@titlelogocode

    \node[
      anchor=west,
      NMBUwhite,
      inner sep=0pt,
      align=left,
      text width=12.0cm
    ] (T) at ($(current page.west) + (0.8,0.30)$)
      {%
        \usebeamerfont{title}%
        \fontsize{23pt}{26pt}\selectfont
        \raggedright\inserttitle\par
      };

    \node[
      anchor=north west,
      NMBUwhite,
      inner sep=0pt,
      align=left,
      text width=12.0cm
    ] (A) at ($(current page.west) + (0.8,-0.50)$)
      {\fontsize{12pt}{14pt}\selectfont\insertauthor\par};

    \ifx\insertsubtitle\@empty\else
      \node[
        anchor=north west,
        NMBUwhite,
        inner sep=0pt,
        align=left,
        text width=12.0cm
      ] (ST) at ($(current page.west) + (0.9,-1.70)$)
        {\fontsize{12pt}{14pt}\selectfont\insertsubtitle\par};
    \fi

    \node[
      anchor=north west,
      NMBUwhite,
      inner sep=0pt,
      align=left,
      text width=12.0cm
    ] (D) at ($(current page.west) + (0.9,-2.30)$)
      {\fontsize{12pt}{14pt}\selectfont\insertdate\par};

    \draw[line width=0.10mm,NMBUwhite]
      ($(current page.south west) + (0.9,0.82)$)
      --
      ($(current page.south east) + (-0.9,0.82)$);

    \node[anchor=north east,NMBUwhite,inner sep=0pt,align=right]
      at ($(current page.south east) + (-0.9,0.72)$)
      {\fontsize{7pt}{8pt}\selectfont\insertinstitute\par};
  \end{tikzpicture}%
}

