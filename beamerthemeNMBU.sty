  \begin{beamercolorbox}[
    wd=\paperwidth,
    ht=\NMBU@frametitleheight,
    dp=1.6ex,
    leftskip=9mm,
    rightskip=9mm
  ]{frametitle}
    \usebeamerfont{frametitle}%
    \textcolor{\NMBU@frameaccent}{\insertframetitle}%
    \\[0.1em]%
    \usebeamerfont{framesubtitle}\insertframesubtitle
  \end{beamercolorbox}%
}

\newcommand*\NMBU@titlelogocode{}
\newcommand*\NMBU@framelogocode{}
\newcommand*\NMBU@titlelogorow{}
\newcommand*\NMBU@framelogorow{}

\newlength{\NMBUtitlelogogap}
\newlength{\NMBUframelogogap}
\setlength{\NMBUtitlelogogap}{0.45cm}
\setlength{\NMBUframelogogap}{0.35cm}

\newcommand*\NMBUtitlelogos[1]{%
  \gdef\NMBU@titlelogocode{#1}%
}

\newcommand*\NMBUframelogos[1]{%
  \gdef\NMBU@framelogocode{#1}%
}

\newcommand*\NMBUcleartitlelogos{%
  \global\let\NMBU@titlelogocode\@empty
  \global\let\NMBU@titlelogorow\@empty
}

\newcommand*\NMBUclearframelogos{%
  \global\let\NMBU@framelogocode\@empty
  \global\let\NMBU@framelogorow\@empty
}

\newcommand*\NMBU@appendtitlelogofile[2]{%
  \ifx\NMBU@titlelogorow\@empty
    \gappto\NMBU@titlelogorow{\includegraphics[#1]{#2}}%
  \else
    \gappto\NMBU@titlelogorow{\hspace{\NMBUtitlelogogap}\includegraphics[#1]{#2}}%
  \fi
}

\newcommand*\NMBU@appendframelogofile[2]{%
  \ifx\NMBU@framelogorow\@empty
    \gappto\NMBU@framelogorow{\includegraphics[#1]{#2}}%
  \else
    \gappto\NMBU@framelogorow{\hspace{\NMBUframelogogap}\includegraphics[#1]{#2}}%
  \fi
}

\newcommand*\NMBUaddtitlelogo[2][height=0.65cm]{%
  \NMBU@appendtitlelogofile{#1}{#2}%
}

\newcommand*\NMBUaddframelogo[2][height=0.38cm]{%
  \NMBU@appendframelogofile{#1}{#2}%
}

\newcommand*\NMBUaddtitlelogonode[3][]{%
  \gappto\NMBU@titlelogocode{%
    \node[inner sep=0pt,#1] at #2 {#3};%
  }%
}

\newcommand*\NMBUaddframelogonode[3][]{%
  \gappto\NMBU@framelogocode{%
    \node[inner sep=0pt,#1] at #2 {#3};%
  }%
}

\newcommand*\NMBU@drawtitlelogorow{%
  \ifx\NMBU@titlelogorow\@empty
    % No extra title-page logo files supplied.
  \else
    \node[anchor=north east,inner sep=0pt]
      at ($(current page.north east) + (-2.15,-0.50)$)
      {\NMBU@titlelogorow};%
  \fi
}

\newcommand*\NMBU@drawleftframelogorow{%
  \ifx\NMBU@framelogorow\@empty
    % No extra regular-frame logo files supplied.
  \else
    \node[anchor=north west,inner sep=0pt]
      at ($(current page.north west) + (2.45,-0.50)$)
      {\NMBU@framelogorow};%
  \fi
}

\newcommand*\NMBU@drawrightframelogorow{%
  \ifx\NMBU@framelogorow\@empty
    % No extra regular-frame logo files supplied.
  \else
    \node[anchor=north east,inner sep=0pt]
      at ($(current page.north east) + (-2.45,-0.50)$)
      {\NMBU@framelogorow};%
  \fi
}

% --- Logo layer ------------------------------------------------------------

\newcommand*\NMBU@drawleftlogo{%
  \node[anchor=north west,inner sep=0pt]
    at ($(current page.north west) + (0.92,-0.50)$)
    {\resizebox{1.0cm}{!}{\nmbulogo{\NMBU@frameaccent}}};%
}

\newcommand*\NMBU@drawrightlogo{%
  \node[anchor=north east,inner sep=0pt]
    at ($(current page.north east) + (-0.85,-0.50)$)
    {\resizebox{1.0cm}{!}{\nmbulogo{\NMBU@frameaccent}}};%
}

\newcommand*\NMBU@drawlogo{%
  \ifNMBU@nologo
    % Logo layer deliberately suppressed.
  \else
    \ifdefstring{\NMBU@logoside}{left}{%
      \NMBU@drawleftlogo
      \NMBU@drawleftframelogorow
    }{%
      \NMBU@drawrightlogo
      \NMBU@drawrightframelogorow
    }%
    \NMBU@framelogocode
  \fi
}

\newcommand*\NMBU@drawfootline{%
  \ifNMBU@nofootline
    % Footline deliberately suppressed; logo is handled independently.
  \else
    \draw[line width=0.10mm,\NMBU@frameaccent]
      ($(current page.south west) + (0.9,0.82)$) -- ($(current page.south east) + (-0.9,0.82)$);
    \node[anchor=north west,text=\NMBU@frameaccent,inner sep=0pt,align=left]
      at ($(current page.south west) + (0.9,0.72)$)
      {\fontsize{7pt}{8pt}\selectfont\insertframenumber\par};
    \node[anchor=north east,text=\NMBU@frameaccent,inner sep=0pt,align=right]
      at ($(current page.south east) + (-0.9,0.72)$)
      {\fontsize{7pt}{8pt}\selectfont\insertinstitute\par};
  \fi
}

\setbeamertemplate{footline}{%
  \begin{tikzpicture}[overlay,remember picture]
    \NMBU@drawlogo
    \NMBU@drawfootline
  \end{tikzpicture}%
}

