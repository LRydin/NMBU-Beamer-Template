% A custom numbered outline list with:
%   - accent-coloured numbers;
%   - a vertical accent rule between numbers and text;
%   - bold item titles;
%   - smaller grey detail text.
%
% Basic usage:
%
%   \begin{nmbuoutline}
%     \item<1-> First subject
%     \itemdetails<1-> First subject details
%
%     \item<2-> Second subject
%     \itemdetails<3-> Second subject details, appearing later
%   \end{nmbuoutline}
%
% Optional colour override:
%
%   \begin{nmbuoutline}[NMBUAccent2]
%     ...
%   \end{nmbuoutline}
%
% By default, the outline accent follows the current frame accent.

\newcounter{nmbuoutlineitem}
\newcounter{nmbuoutlineblock}

\newlength{\NMBUoutlineNumberWidth}
\newlength{\NMBUoutlineNumberSep}
\newlength{\NMBUoutlineRuleWidth}
\newlength{\NMBUoutlineTextSep}
\newlength{\NMBUoutlineRuleX}
\newlength{\NMBUoutlineLeftMargin}

\newlength{\NMBUoutlineItemSep}
\newlength{\NMBUoutlineTopAdjust}
\newlength{\NMBUoutlineBottomAdjust}
\newlength{\NMBUoutlineNumberRaise}
\newlength{\NMBUoutlineDetailSkip}

\setlength{\NMBUoutlineNumberWidth}{0.75cm}
\setlength{\NMBUoutlineNumberSep}{0.45cm}
\setlength{\NMBUoutlineRuleWidth}{0.55pt}
\setlength{\NMBUoutlineTextSep}{0.55cm}

\setlength{\NMBUoutlineItemSep}{0.32cm}
\setlength{\NMBUoutlineTopAdjust}{0.18cm}
\setlength{\NMBUoutlineBottomAdjust}{-0.35cm}
\setlength{\NMBUoutlineNumberRaise}{-0.8em}
\setlength{\NMBUoutlineDetailSkip}{-0.25em}

\newcommand{\NMBUoutlineNumberFont}{%
  \fontsize{16pt}{18pt}\bfseries\selectfont%
}

\newcommand{\NMBUoutlineTitleFont}{%
  \fontsize{12pt}{14pt}\bfseries\selectfont%
}

\newcommand{\NMBUoutlineDetailFont}{%
  \fontsize{10pt}{12pt}\normalfont\selectfont%
}

\newcommand{\NMBUoutlineTitleColour}{NMBUblack}
\newcommand{\NMBUoutlineDetailColour}{black!55}

\newenvironment{nmbuoutline}[1][\NMBU@frameaccent]{%
  \par
  \begingroup
  \stepcounter{nmbuoutlineblock}%
  \setcounter{nmbuoutlineitem}{0}%
  \colorlet{NMBUoutlineAccent}{#1}%
  \setlength{\NMBUoutlineRuleX}{%
    \dimexpr\NMBUoutlineNumberWidth+\NMBUoutlineNumberSep\relax%
  }%
  \setlength{\NMBUoutlineLeftMargin}{%
    \dimexpr
      \NMBUoutlineNumberWidth
      + \NMBUoutlineNumberSep
      + \NMBUoutlineRuleWidth
      + \NMBUoutlineTextSep
    \relax%
  }%
  \tikz[remember picture,overlay]
    \coordinate (nmbuoutline-top-\thenmbuoutlineblock);
  \begin{list}{}{%
    \setlength{\labelwidth}{\NMBUoutlineNumberWidth}%
    \setlength{\labelsep}{%
      \dimexpr
        \NMBUoutlineNumberSep
        + \NMBUoutlineRuleWidth
        + \NMBUoutlineTextSep
      \relax%
    }%
    \setlength{\leftmargin}{\NMBUoutlineLeftMargin}%
    \setlength{\rightmargin}{0pt}%
    \setlength{\topsep}{0pt}%
    \setlength{\partopsep}{0pt}%
    \setlength{\parsep}{0pt}%
    \setlength{\itemsep}{\NMBUoutlineItemSep}%
  }%
  \let\NMBUoutlineOldItem\item
  \renewcommand<>{\item}{%
    \onslide<1->%
    \stepcounter{nmbuoutlineitem}%
    \NMBUoutlineOldItem##1[%
      \hbox to \NMBUoutlineNumberWidth{%
        \hfil
        \raisebox{\NMBUoutlineNumberRaise}{%
          {\NMBUoutlineNumberFont\color{NMBUoutlineAccent}\arabic{nmbuoutlineitem}}%
        }%
      }%
    ]%
    \NMBUoutlineTitleFont
    \color{\NMBUoutlineTitleColour}%
    \ignorespaces
  }%
  \newcommand<>{\NMBUoutlineItemDetails}{%
    \par
    \vspace{\NMBUoutlineDetailSkip}%
    \NMBUoutlineDetailFont
    \color{\NMBUoutlineDetailColour}%
    \def\NMBUoutlineOverlaySpec{##1}%
    \ifx\NMBUoutlineOverlaySpec\@empty
    \else
      \onslide##1%
    \fi
    \ignorespaces
  }%
  \let\itemdetails\NMBUoutlineItemDetails
}{%
  \end{list}%
  \tikz[remember picture,overlay]
    \coordinate (nmbuoutline-bottom-\thenmbuoutlineblock);
  \begin{tikzpicture}[remember picture,overlay]
    \draw[
      NMBUoutlineAccent,
      line width=\NMBUoutlineRuleWidth
    ]
      ([xshift=\NMBUoutlineRuleX,yshift=-\NMBUoutlineTopAdjust]
        nmbuoutline-top-\thenmbuoutlineblock)
      --
      ([xshift=\NMBUoutlineRuleX,yshift=-\NMBUoutlineBottomAdjust]
        nmbuoutline-bottom-\thenmbuoutlineblock);
  \end{tikzpicture}%
  \par
  \endgroup
}

