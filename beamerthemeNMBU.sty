\setbeamercolor{block body alerted}{fg=NMBUblack,bg=NMBUAccent3}

\setbeamercolor{author in head/foot}{fg=NMBUPrimary,bg=}
\setbeamercolor{date in head/foot}{fg=NMBUPrimary,bg=}
\setbeamercolor{NMBU foot rule}{fg=NMBUPrimary,bg=}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]

\newcommand*\NMBU@frameaccentdefault{NMBUPrimary}
\def\NMBU@frameaccent{\NMBU@frameaccentdefault}

% Valid logo-side values are 'left' and 'right'. The default is 'right' to
% preserve the earlier NMBU theme layout.
\def\NMBU@logoside{right}

\newif\ifNMBU@nofootline
\newif\ifNMBU@nologo
\NMBU@nofootlinefalse
\NMBU@nologofalse

\define@key{beamerframe}{framecolor}{%
  \def\NMBU@frameaccent{#1}%
}

\define@key{beamerframe}{footline}[true]{%
  \ifdefstring{#1}{false}{%
    \NMBU@nofootlinetrue
  }{%
    \NMBU@nofootlinefalse
  }%
}

\define@key{beamerframe}{nofootline}[true]{%
  \ifdefstring{#1}{false}{%
    \NMBU@nofootlinefalse
  }{%
    \NMBU@nofootlinetrue
  }%
}

\define@key{beamerframe}{leftlogo}[true]{%
  \ifdefstring{#1}{false}{%
    \def\NMBU@logoside{right}%
  }{%
    \def\NMBU@logoside{left}%
    \NMBU@nologofalse
  }%
}

\define@key{beamerframe}{rightlogo}[true]{%
  \ifdefstring{#1}{false}{%
    \def\NMBU@logoside{left}%
  }{%
    \def\NMBU@logoside{right}%
    \NMBU@nologofalse
  }%
}

\define@key{beamerframe}{nologo}[true]{%
  \ifdefstring{#1}{false}{%
    \NMBU@nologofalse
  }{%
    \NMBU@nologotrue
  }%
}

\AtBeginDocument{%
  \pretocmd{\beamer@@@@frame}{%
    \def\NMBU@frameaccent{\NMBU@frameaccentdefault}%
    \def\NMBU@logoside{right}%
    \NMBU@nofootlinefalse
    \NMBU@nologofalse
  }{}{%
    \PackageWarning{beamerthemeNMBU}{Could not patch Beamer frame initialisation; frame options may persist across frames}%
  }%
}

\setbeamercolor{frametitle}{fg=,bg=}

\setbeamertemplate{frametitle}{%
