\ProvidesPackage{beamerthemeNMBU}[2026/06/23 v0.3.0 NMBU Beamer theme]

% This file defines a Beamer presentation theme for the Norwegian University
% of Life Sciences (NMBU).
% It provides:
%   - NMBU colour definitions and hyperlink styling;
%   - language-dependent institute and page labels;
%   - font selection for XeLaTeX/LuaLaTeX, with a pdfLaTeX fallback;
%   - frame title, title page, footline, list, block, and caption styling;
%   - a per-frame accent-colour option: [framecolor=<xcolor name>];
%   - per-frame logo controls: [leftlogo], [rightlogo], [nologo];
%   - per-frame footline control: [footline] and [nofootline];
%   - simple filename-based additional logos for title and regular frames;
%   - a custom outline list environment: nmbuoutline;
%   - embedded NMBU logo drawing at the end of the file.
%
% Typical use in a presentation:
%
%   \documentclass[10pt,aspectratio=169]{beamer}
%   \usetheme[
%     lang=en,
%     font=arial,
%     elevatedtitles=true,
%     serifmath=true,
%     tightlists=true
%   ]{NMBU}
%
% Compile with XeLaTeX or LuaLaTeX for Arial/Calibri/Carlito system fonts.
% With pdfLaTeX, the theme falls back to Helvetica when font is not set to none.

\makeatletter

\RequirePackage{kvoptions}
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}
\RequirePackage{ifxetex}
\RequirePackage{ifluatex}

\RequirePackage{tikz}
\usetikzlibrary{calc}
\usetikzlibrary{intersections}
\usetikzlibrary{positioning}

% Options are passed by Beamer through \usetheme[...]{NMBU}; internally this
% is loaded as a package option list, which kvoptions processes here.
%
% font:
%   arial   : use Arial via fontspec under XeLaTeX/LuaLaTeX
%   calibri : use Calibri via fontspec under XeLaTeX/LuaLaTeX
%   carlito : use Carlito via fontspec under XeLaTeX/LuaLaTeX
%   none    : do not alter the document fonts
%
% elevatedtitles:
%   true  : compact title strip, leaving more vertical space on the slide
%   false : taller title strip
%
% serifmath:
%   true  : keep mathematics in a serif math font
%   false : use Beamer's default sans-style math behaviour
%
% tightlists:
%   true  : slightly tighter standard itemize lists
%   false : leave Beamer defaults mostly untouched
%
% lang:
%   en : English labels
%   bm : Norwegian Bokmål labels
%   nn : Norwegian Nynorsk labels

\SetupKeyvalOptions{family=NMBU,prefix=NMBU@}

\DeclareStringOption[arial]{font}
\DeclareBoolOption[true]{elevatedtitles}
\DeclareBoolOption[true]{serifmath}
\DeclareBoolOption[true]{tightlists}
\DeclareStringOption[en]{lang}

\ProcessKeyvalOptions*

\def\NMBU@babel@en{english}
\def\NMBU@babel@bm{norwegian}
\def\NMBU@babel@nn{nynorsk}

\providecommand\NMBU@inst@en{Norwegian University of Life Sciences}
\providecommand\NMBU@inst@bm{Norges miljø- og biovitenskapelige universitet}
\providecommand\NMBU@inst@nn{Noregs miljø- og biovitskaplege universitet}

\providecommand\NMBU@page@en{page}
\providecommand\NMBU@page@bm{side}
\providecommand\NMBU@page@nn{side}

\@ifundefined{NMBU@babel@\NMBU@lang}{%
  \PackageWarning{beamerthemeNMBU}{Unknown language '\NMBU@lang'. Falling back to English}%
  \def\NMBU@lang{en}%
}{}

\newcommand*\NMBU@babelname{\csname NMBU@babel@\NMBU@lang\endcsname}
\newcommand*\NMBU@InstituteName{\csname NMBU@inst@\NMBU@lang\endcsname}
\newcommand*\NMBU@PageName{\csname NMBU@page@\NMBU@lang\endcsname}

\expandafter\RequirePackage\expandafter[\NMBU@babelname]{babel}
\institute{\NMBU@InstituteName}

% NMBUPrimary is the main green/teal accent used for titles, logos, and the
% footline. The colour names are intentionally stable so user documents can
% rely on them.

\definecolor{NMBUblack}{HTML}{000000}
\definecolor{NMBUwhite}{HTML}{FFFFFF}

\definecolor{NMBUPrimary}{HTML}{009D7F}
\definecolor{NMBUAccent2}{HTML}{E7E3D1}
\definecolor{NMBUAccent3}{HTML}{F6F6EE}
\definecolor{NMBUwarmgrey}{HTML}{E8E3DC}
\definecolor{NMBUgreenish}{HTML}{A1B7AC}
\definecolor{NMBUlightblue}{HTML}{ACC5E0}

\RequirePackage{hyperref}

\hypersetup{
  colorlinks=true,
  citecolor=NMBUPrimary,
  linkcolor=NMBUPrimary,
  urlcolor=NMBUPrimary
}

\urlstyle{same}
\DeclareUrlCommand\url{\color{NMBUPrimary}}

\newif\ifNMBU@usefontspec
\NMBU@usefontspecfalse

\ifxetex
  \NMBU@usefontspectrue
\fi
\ifluatex
  \NMBU@usefontspectrue
\fi

\ifdefstring{\NMBU@font}{none}{%
  \NMBU@usefontspecfalse
}{}

\ifNMBU@usefontspec
  \RequirePackage{fontspec}

  \newcommand*\NMBU@setfontwithfallback[2]{%
    \IfFontExistsTF{#1}{%
      \setsansfont{#1}%
      \setmainfont{#1}%
    }{%
      \PackageWarning{beamerthemeNMBU}{Font '#1' not found. Falling back to '#2'}%
      \IfFontExistsTF{#2}{%
        \setsansfont{#2}%
        \setmainfont{#2}%
      }{%
        \PackageWarning{beamerthemeNMBU}{Fallback font '#2' not found. Falling back to TeX Gyre Heros}%
        \setsansfont{TeX Gyre Heros}%
        \setmainfont{TeX Gyre Heros}%
      }%
    }%
  }

  \ifdefstring{\NMBU@font}{calibri}{%
    \NMBU@setfontwithfallback{Calibri}{Carlito}%
  }{%
    \ifdefstring{\NMBU@font}{carlito}{%
      \NMBU@setfontwithfallback{Carlito}{TeX Gyre Heros}%
    }{%
      \ifdefstring{\NMBU@font}{arial}{%
        \NMBU@setfontwithfallback{Arial}{Carlito}%
      }{%
        \PackageWarning{beamerthemeNMBU}{Unknown font option '\NMBU@font'. Falling back to Arial/Carlito}%
        \NMBU@setfontwithfallback{Arial}{Carlito}%
      }%
    }%
  }%
\else
  \ifdefstring{\NMBU@font}{none}{%
    % Leave all font choices to the document.
  }{%
    \RequirePackage[scaled=0.8]{helvet}
    \renewcommand{\familydefault}{\sfdefault}
  }%
\fi

\ifNMBU@serifmath
  \usefonttheme[onlymath]{serif}
\fi

