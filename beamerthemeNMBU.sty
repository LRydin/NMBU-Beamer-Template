\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{beamerthemeNMBU}[2025/10/12 v0.2 NMBU Beamer theme]

\RequirePackage{xcolor}
\RequirePackage{graphicx}
\RequirePackage{etoolbox}
\RequirePackage{ifxetex}
\RequirePackage{ifluatex}

\RequirePackage{tikz}
\usetikzlibrary{calc}
\usetikzlibrary{intersections}
\usetikzlibrary{positioning}

\SetupKeyvalOptions{family=NMBU, prefix=NMBU@}
\DeclareStringOption[arial]{font}     % arial|calibri|none (none = don't touch fonts)
\DeclareBoolOption[true]{elevatedtitles}
\DeclareBoolOption[true]{serifmath}
\DeclareBoolOption[true]{tightlists}   % slightly tighter item spacing
% Three language switch: en (English), bm (Bokmål), nn (Nynorsk)
\DeclareStringOption[en]{lang}
\ProcessKeyvalOptions*

% Mapping to babel/polyglossia language tags 
\def\NMBU@babel@en{english}
\def\NMBU@babel@bm{norwegian} % Bokmål
\def\NMBU@babel@nn{nynorsk}
\newcommand*\NMBU@babelname{\csname NMBU@babel@\NMBU@lang\endcsname}

% Load babel
\expandafter\RequirePackage\expandafter[\NMBU@babelname]{babel}

% Define institutional name for the three languages
\providecommand\NMBU@inst@en{Norwegian University of Life Sciences}
\providecommand\NMBU@inst@bm{Norges miljø- og biovitenskapelige universitet}
\providecommand\NMBU@inst@nn{Noregs miljø- og biovitskaplege universitet}

\newcommand*\NMBU@InstituteName{\csname NMBU@inst@\NMBU@lang\endcsname}
\institute{\NMBU@InstituteName}


% Colour definitions. More should be added.
\definecolor{NMBUblack}{HTML}{000000}    % Black 
\definecolor{NMBUwhite}{HTML}{FFFFFF}    % White 
\definecolor{NMBUPrimary}{HTML}{009D7F}  % accent1 (green/teal)
\definecolor{NMBUAccent2}{HTML}{E7E3D1}  % accent2 (amber)
\definecolor{NMBUAccent3}{HTML}{F6F6EE}  % accent3 (slate)
% I note here that the official green of NMBU is the {RGB}{0,133,113}, but for some reason, all the templates we use use a different green. Beats me.

% Hyperlinks related packages
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,citecolor=NMBUPrimary}
\urlstyle{same}
\DeclareUrlCommand\url{\color{NMBUPrimary}}

% Font setup (Arial by default as per NMBU standard)
\newif\ifnmbu@fontspec
\ifxetex\nmbu@fontspectrue\fi
\ifluatex\nmbu@fontspectrue\fi

\ifstrequal{\NMBU@font}{none}{\nmbu@fontspecfalse}{}%

\ifnmbu@fontspec
  \RequirePackage{fontspec}
  \ifstrequal{\NMBU@font}{calibri}{%
    \setsansfont{Calibri}
    \setmainfont{Calibri}
  }{%
    % default Arial
    \setsansfont{Arial}
    \setmainfont{Arial}
  }%
\else
  % pdfLaTeX fallback: use Helvetica for a similar look
  \RequirePackage[scaled=0.92]{helvet}
  \renewcommand{\familydefault}{\sfdefault}
\fi

\def\elevatedtitleheight{6.2ex}
\ifNMBU@elevatedtitles 
    \renewcommand\elevatedtitleheight{3.0ex}
\fi

\ifNMBU@serifmath 
    \usefonttheme[onlymath]{serif}
\fi

\RequirePackage{lmodern}

% Arial font with XeLaTeX or LuaLaTeX
\RequirePackage{fontspec}
\setsansfont{Arial}
\setmainfont{Arial}

% Shorter caption spacing
\setlength{\abovecaptionskip}{5pt plus 3pt minus 2pt}

% Core beamer palette & typography
\mode<presentation>

% Base text & structure
\setbeamercolor{normal text}{fg=NMBUblack,bg=NMBUwhite}
\setbeamercolor{structure}{fg=NMBUPrimary}
\setbeamercolor{alerted text}{fg=NMBUAccent2}

% Frame title bar (colored) and title colors
\setbeamercolor{frametitle}{fg=NMBUPrimary,bg=}
\setbeamertemplate{frametitle}{%
    \nointerlineskip
    \begin{beamercolorbox}[wd=\paperwidth,ht=\elevatedtitleheight,dp=1.6ex,leftskip=10mm,rightskip=10mm]{frametitle}
      \usebeamerfont{frametitle}\insertframetitle\\[0.1em]
      \usebeamerfont{framesubtitle}\insertframesubtitle
    \end{beamercolorbox}%
}


\setbeamerfont{frametitle}{size=\Large}
\setbeamerfont{framesubtitle}{size=\normalsize}

\setbeamerfont{title}{size=\huge}
\setbeamerfont{subtitle}{size=\large}
\setbeamerfont{author}{size=\large}
\setbeamerfont{institute}{size=\large}
\setbeamerfont{date}{size=\large}
\setbeamerfont{block title}{size=\normalsize}
\setbeamerfont{footnote}{size=\scriptsize}

% Margins & vertical rhythm
\setbeamersize{text margin left=10mm, text margin right=10mm}
\linespread{1.06}
\setlength{\parskip}{0.28\baselineskip}

% Lists
\setbeamercolor{itemize item}{fg=NMBUPrimary}
\setbeamercolor{itemize subitem}{fg=NMBUAccent3}
\setbeamertemplate{itemize item}{\raise0.6pt\hbox{\large\textbullet}}
\setbeamertemplate{itemize subitem}{\textendash}
\ifNMBU@tightlists
  \setlength{\leftmargini}{1.4em}
  \setlength{\itemsep}{0.25\baselineskip}
\fi

% Blocks (use amber/secondary accent for titles, light background for body)
\setbeamertemplate{blocks}[rounded][shadow=false]
\setbeamercolor{block title}{fg=NMBUblack,bg=NMBUAccent2}
\setbeamercolor{block body}{fg=NMBUblack,bg=NMBUAccent3}
\setbeamercolor{block title example}{fg=NMBUblack,bg=NMBUAccent2}
\setbeamercolor{block body example}{fg=NMBUblack,bg=NMBUAccent3}
\setbeamercolor{block title alerted}{fg=NMBUblack,bg=NMBUAccent2}
\setbeamercolor{block body alerted}{fg=NMBUblack,bg=NMBUAccent3}


% Example/theorem colors (cooler palette)
\setbeamercolor{author in head/foot}{fg=NMBUPrimary,bg=}
\setbeamercolor{date in head/foot}{fg=NMBUPrimary,bg=}
\setbeamercolor{nmbu foot rule}{fg=NMBUPrimary,bg=}

\setbeamertemplate{navigation symbols}{}
\setbeamertemplate{caption}[numbered]

% Footline: rule + page (left) and NMBU (right)
\setbeamertemplate{footline}{%
\begin{tikzpicture}[overlay, remember picture]
    \node[below right, inner sep=0pt] at ($(current page.north east)+(-2, -0.25)$) {\enlogo{NMBUPrimary}};
    \draw[line width=0.12mm, NMBUPrimary, inner sep=0pt] ($(current page.south west)+(0.9, 0.8)$) -- ($(current page.south east)+(-0.9, 0.8)$);
    \node[below right, NMBUPrimary, inner sep=0pt] at ($(current page.south west)+(0.9, 0.7)$) {\fontsize{5.5pt}{6.5pt}\selectfont\insertframenumber\par};
    \node[below left, NMBUPrimary, inner sep=0pt] at ($(current page.south east)+(-0.9, 0.7)$) {\fontsize{5.7pt}{6.5pt}\selectfont\insertinstitute\par};
\end{tikzpicture}
}

% Title page with primary background, white text
\setbeamercolor{title}{fg=NMBUwhite,bg=NMBUPrimary}
\defbeamertemplate*{title page}{nmbu}[1][]{%
\begin{tikzpicture}[overlay, remember picture]
    \fill [NMBUPrimary, inner sep=0pt] ($(current page.north west)$) -- ($(current page.north east)$) -- ($(current page.south east)$) -- ($(current page.south west)$) -- ($(current page.north west)$);
    \node[below right, NMBUPrimary, inner sep=0pt] at ($(current page.north east)+(-2, -0.25)$) {\resizebox{0.1cm}{!}{\enlogo{NMBUwhite}}};
    \node[right, NMBUwhite, inner sep=0pt] at ($(current page.west) + (0.9,0.3)$) {\fontsize{23pt}{26pt}\selectfont\inserttitle\par};
    \node[right, NMBUwhite, inner sep=0pt] at ($(current page.west) + (0.9,-0.5)$) {\fontsize{12pt}{14pt}\selectfont\insertauthor\par};
    \node[right, NMBUwhite, inner sep=0pt] at ($(current page.west) + (0.9,-1.7)$) {\fontsize{12pt}{14pt}\selectfont\insertsubtitle\par};
    \node[right, NMBUwhite, inner sep=0pt] at ($(current page.west) + (0.9,-2.3)$) {\fontsize{12pt}{14pt}\selectfont\insertdate\par};
    \draw[line width=0.12mm, NMBUwhite, inner sep=0pt] ($(current page.south west)+(0.9, 0.8)$) -- ($(current page.south east)+(-0.9, 0.8)$);
    \node[below left, NMBUwhite, inner sep=0pt] at ($(current page.south east)+(-0.9, 0.7)$) {\fontsize{5.7pt}{6.5pt}\selectfont\insertinstitute\par};
\end{tikzpicture}
}

\setbeamertemplate{title page}[nmbu]

\renewcommand\footnoterule{}
\setbeamertemplate{footnote}{%
% \begin{tikzpicture}[overlay, remember picture]
%     \node[below left, inner sep=0pt] at ($(current page.south east)+(-0.9, 1.15)$) {{\tiny\hbox to 1.8em{\hfil\insertfootnotemark}\insertfootnotetext\par}};
% \end{tikzpicture}
  \raggedleft%\raggedright
  \usebeamercolor{footnote}\tiny\hfil\insertfootnotemark \insertfootnotetext\par%
}

\addtobeamertemplate{footline}{}{\vspace{0.75cm}} 

